# ---------------------------------------------------------------------------
# TRANSITLAB environment configuration
# Copy to .env and fill in. All keys here are for OPEN data sources.
# ---------------------------------------------------------------------------

# --- Database (matches docker-compose.yml) ---------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=transitlab
PGUSER=transitlab
PGPASSWORD=transitlab
# Single-URL alternative consumed by the server if set:
DATABASE_URL=postgresql://transitlab:transitlab@localhost:5432/transitlab

# --- Server ----------------------------------------------------------------
# Ports are offset from the defaults so TRANSITLAB can run alongside other
# local projects (e.g. another app on 4000/5173).
PORT=4010
# Secret used to sign JWTs. Change in any non-local deployment.
JWT_SECRET=dev-only-change-me
# Comma-separated allowed CORS origins for the API.
CORS_ORIGIN=http://localhost:5174

# --- Client (Vite, must be prefixed VITE_) ---------------------------------
VITE_API_BASE=http://localhost:4010
# Optional MapTiler key for a muted vector base style. If absent the client
# falls back to a free OSM raster base. Get a free key at maptiler.com.
VITE_MAPTILER_KEY=

# ---------------------------------------------------------------------------
# Seed pipeline API keys (free registration). See server/src/scripts/seed/.
# ---------------------------------------------------------------------------

# TfL Unified API — register a free app key at https://api-portal.tfl.gov.uk
TFL_APP_KEY=

# Overpass API endpoint (national rail / freight geometry from OpenStreetMap).
# Default public instance; swap for a private mirror to avoid rate limits.
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ONS Open Geography Portal — no key required; URLs are pinned in the seed script.
# Override here only if the published dataset endpoints change.
ONS_LSOA_BOUNDARY_URL=
ONS_LSOA_POPULATION_URL=
