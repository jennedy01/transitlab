{
  "name": "@transitlab/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/scripts/seed/index.ts",
    "seed:rolling-stock": "tsx src/scripts/seed/rolling-stock.ts",
    "seed:population": "tsx src/scripts/seed/ons-population.ts",
    "seed:tfl": "tsx src/scripts/seed/tfl.ts",
    "seed:overpass": "tsx src/scripts/seed/overpass.ts",
    "seed:demo": "tsx src/scripts/seed/demo-scheme.ts"
  },
  "dependencies": {
    "@transitlab/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
