{
  "name": "transitlab",
  "version": "0.1.0",
  "private": true,
  "description": "TRANSITLAB — a transport planning studio for designing rail and transit lines across the UK",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "migrate": "npm --workspace server run migrate",
    "seed": "npm --workspace server run seed",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "build": "npm --workspace shared run build && npm --workspace server run build && npm --workspace client run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
